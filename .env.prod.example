# AirWay backend · variables de producción (server atenea.komiia.com)
# Copiar a `.env` en la raíz del repo. Nunca commitear.

# ── Postgres (contenedor local) ────────────────────────
DB_PASSWORD=CAMBIAR_password_seguro_aqui

# ── Django ─────────────────────────────────────────────
DEBUG=False
SECRET_KEY=CAMBIAR_con_python_-c_"import_secrets;print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=api.atenea.komiia.com,atenea.komiia.com,localhost,127.0.0.1

# ── CORS (orígenes que pueden consumir la API) ─────────
# Añade aquí tu deploy de Vercel cuando lo tengas
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://atenea.komiia.com,https://airway.vercel.app

# ── OpenAQ (https://explore.openaq.org/register) ──────
OPENAQ_API_KEY=

# ── WAQI (https://aqicn.org/data-platform/token) ──────
WAQI_TOKEN=

# ── LLM: Gemini ────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
