# AirWay — variables de entorno (copia este archivo a .env y llena los valores)

# ── PostgreSQL (desarrollo local con Docker) ───────────
DB_PASSWORD=your_db_password
DB_HOST=db
DB_PORT=5432

# ── OpenAQ (https://explore.openaq.org/register) ──────
OPENAQ_API_KEY=your_openaq_api_key

# ── WAQI (https://aqicn.org/data-platform/token) ──────
WAQI_TOKEN=your_waqi_token

# ── LLM: "gemini" o "alt" ──────────────────────────────
LLM_PROVIDER=gemini

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash-lite

# Proveedor alternativo (OpenAI-compatible API)
# ALT_LLM_API_KEY=
# ALT_LLM_API_URL=
# ALT_LLM_MODEL=gpt-4o-mini

# ── Production (Render sets these automatically) ───────
# SECRET_KEY=
# DEBUG=False
# ALLOWED_HOSTS=
# DATABASE_URL=
# CORS_ALLOWED_ORIGINS=
